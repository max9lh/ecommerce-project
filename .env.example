# ============================================================
# Gestor Financiero Automatizado - Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copiar este archivo: cp .env.example .env
#   2. Completar TODOS los valores marcados con TODO
#   3. NUNCA commitear el archivo .env al repositorio
# ============================================================

# ---- Entorno ----
NODE_ENV=production
PORT=3000

# ---- Base de Datos PostgreSQL ----
# Formato: postgresql://usuario:contraseña@host:puerto/base_datos
DATABASE_URL=postgresql://gestor_user:TODO_cambiar_por_password_seguro_min16chars@localhost:5432/gestor_financiero

# ---- JWT (JSON Web Token) ----
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TODO_generar_secret_aleatorio_muy_largo_minimo_32_caracteres
JWT_EXPIRES_IN=15m

# ---- Refresh Token ----
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
REFRESH_SECRET=TODO_generar_refresh_secret_muy_largo_minimo_32_caracteres
REFRESH_EXPIRES_IN=30d

# ---- Bcrypt ----
# Rounds: 10 = rápido (dev), 12 = recomendado (prod), 14 = muy seguro (lento)
BCRYPT_ROUNDS=12

# ---- CORS ----
# En producción: el dominio real del frontend (ej: https://mi-negocio.com)
CORS_ORIGIN=https://localhost

# ---- Frontend (React/Vite) ----
# URL de la API que el frontend consume (debe ser accesible desde el navegador)
VITE_API_URL=https://localhost/api