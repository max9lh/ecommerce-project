generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  EMPLOYEE
}

// ============================================================
// CORE — Usuarios
// ============================================================

model User {
  id                 Int                 @id @default(autoincrement())
  username           String              @unique
  password_hash      String
  role               Role                @default(EMPLOYEE)

  // Porcentajes de distribución — solo relevantes para el ADMIN
  pct_merchandise    Decimal             @default(0.60) @db.Decimal(3, 2)
  pct_fixed_expenses Decimal             @default(0.30) @db.Decimal(3, 2)
  pct_savings        Decimal             @default(0.10) @db.Decimal(3, 2)

  // Relaciones financieras (solo el ADMIN tendrá registros aquí)
  accounts           Account[]
  budget_balances    BudgetBalance[]
  budget_allocations BudgetAllocation[]
  providers          Provider[]

  // Historial de operaciones — user_id guarda quién operó (trazabilidad)
  daily_closures     DailyClosure[]
  expenses           Expense[]
  auditLogs          AuditLog[]

  // Relaciones exclusivas del EMPLOYEE
  employeeProfile    EmployeeProfile?
  employeePermission EmployeePermission?
  attendanceLogs     AttendanceLog[]

  created_at         DateTime            @default(now())
  deleted_at         DateTime?
}

// ============================================================
// FINANCIERO — Cuentas físicas (solo del ADMIN)
// ============================================================

model Account {
  id                    Int                  @id @default(autoincrement())
  user_id               Int
  user                  User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name                  String               @db.VarChar(20)
  balance               Decimal              @default(0.00) @db.Decimal(15, 2)
  daily_closure_details DailyClosureDetail[]
  expenses              Expense[]
}

// ============================================================
// FINANCIERO — Bolsas virtuales de presupuesto (solo del ADMIN)
// ============================================================

model BudgetBalance {
  id       Int     @id @default(autoincrement())
  user_id  Int
  user     User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category String  @db.VarChar(50)
  balance  Decimal @default(0.00) @db.Decimal(15, 2)

  @@unique([user_id, category])
}

// ============================================================
// OPERACIONES — Cierres de caja
// user_id = quién operó (empleado o admin), no el dueño de las cuentas
// ============================================================

model DailyClosure {
  id                 Int                  @id @default(autoincrement())
  user_id            Int
  user               User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  total_amount       Decimal              @db.Decimal(15, 2)
  date               DateTime             @default(now())
  details            DailyClosureDetail[]
  budget_allocations BudgetAllocation[]
}

model DailyClosureDetail {
  id         Int          @id @default(autoincrement())
  closure_id Int
  closure    DailyClosure @relation(fields: [closure_id], references: [id], onDelete: Cascade)
  account_id Int
  account    Account      @relation(fields: [account_id], references: [id])
  amount     Decimal      @db.Decimal(15, 2)
}

model BudgetAllocation {
  id               Int          @id @default(autoincrement())
  closure_id       Int
  closure          DailyClosure @relation(fields: [closure_id], references: [id], onDelete: Cascade)
  user_id          Int
  user             User         @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category         String       @db.VarChar(50)
  amount_allocated Decimal      @db.Decimal(15, 2)
}

// ============================================================
// OPERACIONES — Proveedores y Gastos
// user_id = quién registró/pagó el gasto (trazabilidad)
// ============================================================

model Provider {
  id                  Int       @id @default(autoincrement())
  user_id             Int
  user                User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  name                String    @db.VarChar(100)
  payment_condition   String    @db.VarChar(20)
  credit_days         Int       @default(0)
  visible_to_employee Boolean   @default(true)
  expenses            Expense[]
}

model Expense {
  id              Int       @id @default(autoincrement())
  user_id         Int
  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  provider_id     Int
  provider        Provider  @relation(fields: [provider_id], references: [id])
  account_id      Int
  account         Account   @relation(fields: [account_id], references: [id])
  budget_category String    @db.VarChar(50)
  amount          Decimal   @db.Decimal(15, 2)
  status          String    @default("Pagado")
  due_date        DateTime?
  paid_at         DateTime?
  created_at      DateTime  @default(now())
  deleted_at      DateTime?
}

// ============================================================
// EMPLEADOS — Permisos (qué acciones puede hacer cada EMPLOYEE)
// ============================================================

model EmployeePermission {
  id                  Int     @id @default(autoincrement())
  user_id             Int     @unique
  user                User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  canRegisterClosures Boolean @default(false)
  canRegisterExpenses Boolean @default(false)
  canPayExpenses      Boolean @default(false)
  canManageProviders  Boolean @default(false)
}

// ============================================================
// EMPLEADOS — Perfil de remuneración
// ============================================================

model EmployeeProfile {
  id             Int      @id @default(autoincrement())
  user_id        Int      @unique
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  first_name     String   @db.VarChar(50)
  last_name      String   @db.VarChar(50)
  salary_type    String   @default("hourly") @db.VarChar(20) // "hourly" | "fixed"
  hourly_rate    Decimal  @default(0.00) @db.Decimal(15, 2)
  monthly_salary Decimal? @db.Decimal(15, 2)
}

// ============================================================
// EMPLEADOS — Registro de asistencia (cargado manualmente por el ADMIN)
// ============================================================

model AttendanceLog {
  id            Int       @id @default(autoincrement())
  employee_id   Int
  employee      User      @relation(fields: [employee_id], references: [id], onDelete: Cascade)
  check_in      DateTime
  check_out     DateTime?
  hours_worked  Decimal?  @db.Decimal(5, 2)
  amount_earned Decimal?  @db.Decimal(15, 2)
  notes         String?   @db.VarChar(255)
  created_at    DateTime  @default(now())
}

// ============================================================
// AUDITORÍA — Registro de acciones realizadas por usuarios
// ============================================================

model AuditLog {
  id          Int      @id @default(autoincrement())
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  action      String   @db.VarChar(100) // "REGISTRAR_CIERRE", "CREAR_PROVEEDOR", "PAGAR_EGRESO", "ELIMINAR_EGRESO", etc.
  details     String   @db.Text
  created_at  DateTime @default(now())
}