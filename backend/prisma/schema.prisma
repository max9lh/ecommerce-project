generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  username           String              @unique
  password_hash      String
  email              String?             @unique   // Campo para recuperación de contraseña
  pct_merchandise    Decimal             @default(0.60) @db.Decimal(3, 2)
  pct_fixed_expenses Decimal             @default(0.30) @db.Decimal(3, 2)
  pct_savings        Decimal             @default(0.10) @db.Decimal(3, 2)
  created_at         DateTime            @default(now())
  role               Role                @default(EMPLOYEE)
  refresh_token_hash String?             @db.Text
  deleted_at            DateTime?
  must_change_password  Boolean             @default(true)
  accounts           Account[]
  attendanceLogs     AttendanceLog[]
  auditLogs          AuditLog[]
  budget_allocations BudgetAllocation[]
  budget_balances    BudgetBalance[]
  daily_closures     DailyClosure[]
  employeePermission EmployeePermission?
  employeeProfile    EmployeeProfile?
  expenses           Expense[]
  providers          Provider[]
  recurring_expenses RecurringExpense[]
  password_reset_tokens PasswordResetToken[]

  @@index([deleted_at])
  @@index([refresh_token_hash])
  @@index([email])
}

model Account {
  id                    Int                  @id @default(autoincrement())
  user_id               Int
  name                  String               @db.VarChar(20)
  balance               Decimal              @default(0.00) @db.Decimal(15, 2)
  user                  User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  daily_closure_details DailyClosureDetail[]
  expenses              Expense[]

  @@index([user_id])
}

model BudgetBalance {
  id       Int     @id @default(autoincrement())
  user_id  Int
  category String  @db.VarChar(50)
  balance  Decimal @default(0.00) @db.Decimal(15, 2)
  user     User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, category])
}

model DailyClosure {
  id                 Int                  @id @default(autoincrement())
  user_id            Int
  total_amount       Decimal              @db.Decimal(15, 2)
  date               DateTime             @default(now())
  budget_allocations BudgetAllocation[]
  user               User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)
  details            DailyClosureDetail[]

  @@index([user_id])
  @@index([date])
}

model DailyClosureDetail {
  id         Int          @id @default(autoincrement())
  closure_id Int
  account_id Int
  amount     Decimal      @db.Decimal(15, 2)
  account    Account      @relation(fields: [account_id], references: [id])
  closure    DailyClosure @relation(fields: [closure_id], references: [id], onDelete: Cascade)

  @@index([closure_id])
  @@index([account_id])
}

model BudgetAllocation {
  id               Int          @id @default(autoincrement())
  closure_id       Int
  category         String       @db.VarChar(50)
  amount_allocated Decimal      @db.Decimal(15, 2)
  user_id          Int
  closure          DailyClosure @relation(fields: [closure_id], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([closure_id])
  @@index([user_id])
}

model Provider {
  id                  Int       @id @default(autoincrement())
  user_id             Int
  name                String    @db.VarChar(100)
  payment_condition   String    @db.VarChar(20)
  credit_days         Int       @default(0)
  visible_to_employee Boolean   @default(true)
  expenses            Expense[]
  user                User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model Expense {
  id              Int       @id @default(autoincrement())
  user_id         Int
  provider_id     Int
  account_id      Int
  budget_category String    @db.VarChar(50)
  amount          Decimal   @db.Decimal(15, 2)
  status          ExpenseStatus @default(Pendiente)
  due_date        DateTime?
  created_at      DateTime  @default(now())
  paid_at         DateTime?
  deleted_at      DateTime?
  account         Account   @relation(fields: [account_id], references: [id])
  provider        Provider  @relation(fields: [provider_id], references: [id])
  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([provider_id])
  @@index([account_id])
  @@index([status])
  @@index([due_date])
  @@index([deleted_at])
}

model EmployeePermission {
  id                  Int     @id @default(autoincrement())
  user_id             Int     @unique
  canRegisterClosures Boolean @default(false)
  canRegisterExpenses Boolean @default(false)
  canPayExpenses      Boolean @default(false)
  canManageProviders  Boolean @default(false)
  user                User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model EmployeeProfile {
  id             Int      @id @default(autoincrement())
  user_id        Int      @unique
  salary_type    String   @default("hourly") @db.VarChar(20)
  hourly_rate    Decimal  @default(0.00) @db.Decimal(15, 2)
  monthly_salary Decimal? @db.Decimal(15, 2)
  first_name     String   @db.VarChar(50)
  last_name      String   @db.VarChar(50)
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model AttendanceLog {
  id            Int       @id @default(autoincrement())
  employee_id   Int
  check_in      DateTime
  check_out     DateTime?
  hours_worked  Decimal?  @db.Decimal(5, 2)
  amount_earned Decimal?  @db.Decimal(15, 2)
  notes         String?   @db.VarChar(255)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  employee      User      @relation(fields: [employee_id], references: [id], onDelete: Cascade)

  @@index([employee_id])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  user_id    Int
  action     String   @db.VarChar(100)
  details    String
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
}

model RecurringExpense {
  id         Int      @id @default(autoincrement())
  user_id    Int
  name       String   @db.VarChar(100)
  amount     Decimal  @db.Decimal(15, 2)
  due_day    Int
  category   String   @default("Gastos Fijos") @db.VarChar(50)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  frequency  String   @default("monthly") @db.VarChar(20)
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model PasswordResetToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token_hash String   @db.Text
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([token_hash])
  @@index([user_id])
}

enum Role {
  ADMIN
  EMPLOYEE
}

enum ExpenseStatus {
  Pendiente
  Pagado
}
