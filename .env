NODE_ENV=production

POSTGRES_DB=gestor_financiero
POSTGRES_USER=gestor_user
POSTGRES_PASSWORD=TODO_cambiar_por_password_seguro_min16chars

# ---- JWT (JSON Web Token) ----
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=TODO_generar_secret_aleatorio_muy_largo
JWT_EXPIRES_IN=7d

# ---- Bcrypt ----
# Rounds: 10 = rápido (dev), 12 = recomendado (prod), 14 = muy seguro (lento)
BCRYPT_ROUNDS=12

CORS_ORIGIN=https://localhost

VITE_API_URL=https://localhost/api
